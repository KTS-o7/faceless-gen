# Bifrost LLM Gateway
BIFROST_BASE_URL=https://opencode.ai/zen/go/v1
BIFROST_API_KEY=your_bifrost_api_key_here
BIFROST_MODEL=gpt-4o-mini

# ElevenLabs TTS
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Video Backend (local = diffusers+MPS, cloud = API)
VIDEO_BACKEND=local

# Cloud video API (only needed if VIDEO_BACKEND=cloud)
CLOUD_VIDEO_API_KEY=
CLOUD_VIDEO_BASE_URL=

# Local Wan I2V model (diffusers format, set after running scripts/download_model.sh)
WAN_MODEL_PATH=./models/wan2.2-i2v-5b

# Output and model directories
OUTPUTS_DIR=./outputs
MODELS_DIR=./models

# ComfyUI server (for image generation)
COMFYUI_BASE_URL=http://127.0.0.1:8188

# Active persona (folder name under backend/assets/personas/)
ACTIVE_PERSONA=default

# FastAPI server
API_HOST=0.0.0.0
API_PORT=8000
